.login-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  width: 100vw;
  background-color: #030811;
  color: #fff;
  position: relative;
  overflow: hidden;
  font-family: 'Inter', -apple-system, sans-serif;
}

/* Partículas animadas */
.particles-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  z-index: 0;
}

.particle {
  position: absolute;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.8) 0%, rgba(59, 130, 246, 0) 70%);
  border-radius: 50%;
  animation: float 20s infinite linear;
  opacity: 0.4;
}

.particle-1 { width: 300px; height: 300px; top: -100px; left: -100px; animation-delay: 0s; }
.particle-2 { width: 400px; height: 400px; bottom: -150px; right: -100px; animation-delay: -5s; background: radial-gradient(circle, rgba(139, 92, 246, 0.6) 0%, rgba(139, 92, 246, 0) 70%); }
.particle-3 { width: 200px; height: 200px; top: 40%; left: 30%; animation-delay: -12s; background: radial-gradient(circle, rgba(16, 185, 129, 0.5) 0%, rgba(16, 185, 129, 0) 70%); }

@keyframes float {
  0% { transform: translateY(0) rotate(0deg) scale(1); }
  33% { transform: translateY(-50px) rotate(120deg) scale(1.1); }
  66% { transform: translateY(50px) rotate(240deg) scale(0.9); }
  100% { transform: translateY(0) rotate(360deg) scale(1); }
}

/* Glass Panel */
.login-container .glass-panel {
  background: rgba(17, 24, 39, 0.6);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24px;
  padding: 48px;
  width: 100%;
  max-width: 440px;
  z-index: 10;
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  transform: translateY(20px);
  animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes slideUp {
  to { transform: translateY(0); }
}

.login-header {
  text-align: center;
  margin-bottom: 32px;
}

.login-container .logo-pulse {
  position: relative;
  width: 64px;
  height: 64px;
  margin: 0 auto 24px auto;
}

.login-container .logo-icon {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  font-weight: 800;
  color: white;
  z-index: 2;
  box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.5);
}

.login-container .pulse-ring {
  position: absolute;
  top: -10px;
  left: -10px;
  right: -10px;
  bottom: -10px;
  border-radius: 20px;
  border: 2px solid rgba(59, 130, 246, 0.5);
  animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  z-index: 1;
}

@keyframes pulse {
  0% { transform: scale(0.9); opacity: 1; }
  100% { transform: scale(1.3); opacity: 0; }
}

.login-header h2 {
  font-size: 28px;
  font-weight: 700;
  margin: 0 0 8px 0;
  letter-spacing: -0.5px;
  background: linear-gradient(to right, #fff, #9ca3af);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.subtitle {
  color: #9ca3af;
  font-size: 15px;
  margin: 0;
}

.login-container .input-group {
  margin-bottom: 20px;
}

.login-container .input-icon-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.login-container .input-icon {
  position: absolute;
  left: 16px;
  color: #6b7280;
  transition: color 0.3s;
}

.login-container .input-icon-wrapper input {
  width: 100%;
  padding: 16px 16px 16px 48px;
  background: rgba(31, 41, 55, 0.5);
  border: 1px solid rgba(75, 85, 99, 0.4);
  border-radius: 12px;
  color: white;
  font-size: 15px;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.login-container .input-icon-wrapper input:focus {
  outline: none;
  background: rgba(31, 41, 55, 0.8);
  border-color: #3b82f6;
  box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
}

.login-container .input-icon-wrapper input:focus + .login-container .input-icon {
  color: #3b82f6;
}

.login-container .btn-login {
  position: relative;
  width: 100%;
  padding: 16px;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
  border: none;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
}

.login-container .btn-login:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.4);
}

.login-container .btn-login:active:not(:disabled) {
  transform: translateY(0);
}

.btn-glow {
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transform: skewX(-20deg);
  transition: 0.5s;
}

.login-container .btn-login:hover:not(:disabled) .btn-glow {
  left: 200%;
}

.error-alert {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.2);
  border-radius: 8px;
  color: #fca5a5;
  margin-bottom: 20px;
  font-size: 14px;
}

.spinner {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.login-footer {
  margin-top: 32px;
  text-align: center;
  color: #6b7280;
  font-size: 13px;
}
